{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AWSCloudTrailAclCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": [
        "s3:GetBucketAcl"
      ],
      "Resource": [
        "${cloudtrail_bucket_arn}"
      ],
      "Condition": {
        "StringEquals": {
          "aws:SourceArn": "arn:${partition}:cloudtrail:${region}:${account_id}:trail/${cloudtrail_name}"
        }
      }
    },
    {
      "Sid": "AWSCloudTrailWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": [
        "s3:PutObject"
      ],
      "Resource": [
        "${cloudtrail_bucket_arn}/${cloudtrail_prefix}/AWSLogs/${account_id}/*"
      ],
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control",
          "aws:SourceArn": "arn:${partition}:cloudtrail:${region}:${account_id}:trail/${cloudtrail_name}"
        }
      }
    }
  ]
}
