{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBucketAccessFromSpecificIPs",
      "Effect": "Allow",
      "Principal": "*",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "${vpc_flow_logs_bucket_arn}"
      ],
      "Condition": {
        "IpAddress": {
          "aws:SourceIp": ${jsonencode(source_ips)}
        }
      }
    },
    {
      "Sid": "AllowObjectAccessFromSpecificIPs",
      "Effect": "Allow",
      "Principal": "*",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "${vpc_flow_logs_bucket_arn}/*"
      ],
      "Condition": {
        "IpAddress": {
          "aws:SourceIp": ${jsonencode(source_ips)}
        }
      }
    },
    {
      "Sid": "AWSLogDeliveryCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": [
        "s3:GetBucketAcl"
      ],
      "Resource": [
        "${vpc_flow_logs_bucket_arn}"
      ],
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "${account_id}"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:${partition}:logs:${region}:${account_id}:*"
        }
      }
    },
    {
      "Sid": "AWSLogDeliveryWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "delivery.logs.amazonaws.com"
      },
      "Action": [
        "s3:PutObject"
      ],
      "Resource": [
        "${vpc_flow_logs_bucket_arn}/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "${account_id}"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:${partition}:logs:${region}:${account_id}:*"
        }
      }
    }
  ]
}
